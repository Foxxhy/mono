{
  "name": "foxxhy-mono",
  "version": "0.1.0",
  "private": false,
  "description": "SCSS/CSS design system with design tokens, global reset, utility classes (u-*), and UI components. Ships minified CSS and full source for Sass consumers.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Foxxhy/mono.git",
    "directory": "packages/design-system"
  },
  "homepage": "https://github.com/Foxxhy/mono/tree/main/packages/design-system",
  "keywords": [
    "foxxhy",
    "scss",
    "sass",
    "css",
    "design-system",
    "design-tokens",
    "components",
    "reset",
    "utility-classes",
    "ui"
  ],
  "style": "dist/design-system.css",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "publish": "npm run lint-fix && npm run build",
    "build": "sass src/index.scss dist/design-system.css --load-path=src --style=compressed --no-source-map",
    "dev": "sass --watch src/index.scss dist/design-system.css --load-path=src --style=expanded --source-map",
    "lint": "stylelint \"src/**/*.scss\"",
    "lint-fix": "stylelint \"src/**/*.scss\" --fix"
  },
  "devDependencies": {
    "@stylistic/stylelint-plugin": "^5.1.0",
    "sass": "^1.85.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0"
  }
}
